{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./scripts/start.sh)",
      "Bash(./scripts/stop.sh)",
      "Bash(tail:*)",
      "Bash(ps:*)",
      "Bash(cat .bot.pid)",
      "Bash(curl https://api.telegram.org/bot*:getMe)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {}
}
