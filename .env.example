# 도클갱어 W2 — .env 템플릿
#
# 1. 이 파일을 `.env` 로 복사하세요:  cp .env.example .env
# 2. 아래 값을 본인 것으로 채우세요.
# 3. `.env` 는 절대 git 에 push 하지 마세요 (.gitignore 에 박혀 있음).
#
# TF-938 hotfix (2026-05-21): Claude API 키 자리 제거.
# Claude Code CLI 를 서브프로세스로 호출하므로 *본인 Claude Code 로그인 상태*면 충분.
# 별도 API 키 발급·결제 불필요. `which claude` 가 경로를 반환하면 OK.

# Telegram Bot 토큰 — BotFather 에서 발급 (docs/botfather-guide.md 참조)
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ── W3 (TF-958) 캘린더 아침 브리핑 ───────────────────────────
# Google Calendar 비공개 iCal URL (1줄, secret 등급).
# 발급: Google Calendar → 설정 → 캘린더 통합 → "캘린더의 비공개 주소(iCal 형식)" 복사.
# ⚠️ 이 URL 은 캘린더 전체 read 권한이에요. 무분별한 공유 금지.
# /setup-ical 스킬이 안내해 줘요. 미설정 시 W3 기능 비활성.
ICAL_URL=

# ── W4 (TF-981) 슬랙 멘션 답변 어시스턴트 (Socket Mode) ──────
# 본인 슬랙에 "도클갱어 답변봇" manifest 를 import 한 뒤 발급되는 토큰 2개.
# 자세한 발급 흐름은 /setup-slack-app 과 /setup-slack-mention 스킬 참조.
# 두 토큰 모두 미설정 시 W4 기능 silent skip — W2/W3 만 운영 가능.
#
# 1) App-Level Token (xapp-...) — Socket Mode 연결용. scope: connections:write
SLACK_APP_TOKEN=
# 2) Bot Token (xoxb-...) — Web API 호출용 (채널/사용자 조회). install 시 발급.
SLACK_BOT_TOKEN=
# 3) (선택) 텔레그램 push chat_id. 비워두면 W3 의 /tmp/doppel-last-chat-id 자동 학습값 사용.
#    본인이 텔레그램 봇에 메시지 1회 보낸 뒤 봇 로그에서 chat_id 확인 가능.
TELEGRAM_PUSH_CHAT_ID=

# ── W5 (TF-1040) 회의록 요약 어시스턴트 ──────────────────────
# 추가 환경변수 *없음*. W5 는 텍스트 붙여넣기만 받아 처리하므로 토큰·URL·키 0건이에요.
# 양식 조정은 config/meeting_notes.yml 에서 (env 아님). /notes 또는 "회의록" 으로 바로 사용.
