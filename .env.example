# 도클갱어 W2 — .env 템플릿
#
# 1. 이 파일을 `.env` 로 복사하세요:  cp .env.example .env
# 2. 아래 두 값을 본인 것으로 채우세요.
# 3. `.env` 는 절대 git에 push하지 마세요 (.gitignore 에 박혀 있음).

# Claude API 키 — https://console.anthropic.com/ 에서 발급
CLAUDE_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telegram Bot 토큰 — BotFather (docs/botfather-guide.md 참조)
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
