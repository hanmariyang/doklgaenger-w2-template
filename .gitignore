# 도클갱어 W2 — git ignore
# 갱이가 절대 push되면 안 되는 것들을 박아 뒀어요 🐾

# 환경변수 — 절대 push 금지
.env
.env.*
!.env.example

# 페르소나 시스템 프롬프트 — 기본은 비공개 (본인이 일부러 공개할 경우만 git add)
persona/system_prompt.md

# W3 브리핑 사용자 설정 — chat_id 같은 개인 정보 보호 (TF-958)
config/briefing.yml

# W4 슬랙 멘션 사용자 설정 — slack_user_id·채널 allowlist 같은 개인 정보 보호 (TF-981)
config/slack_mention.yml

# W5 회의록 양식 — 개인 회의 스타일 설정 보호 (TF-1040)
config/meeting_notes.yml

# 봇 런타임 산출물
.bot.pid
*.log
/tmp/doppel-bot.log

# W5 자유 실습 — 로컬 DB 저장 시 회의 본문 보호 (TF-1040)
*.db
*.sqlite3
meeting_notes.db

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version
*.egg-info/
dist/
build/

