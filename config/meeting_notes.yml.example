# 도클갱어 W5 — 회의록 요약 어시스턴트 설정 (예시)
#
# 1. 이 파일을 `config/meeting_notes.yml` 로 복사하세요:
#       cp config/meeting_notes.yml.example config/meeting_notes.yml
# 2. `/setup-meeting-style` 과 `/tune-meeting-notes` 이 갱이와 대화하며 자동으로 값을 채워줘요.
# 3. 직접 손으로 편집해도 OK. 봇이 매 회의록마다 yml 을 reload — 재시작 불필요.
# 4. `config/meeting_notes.yml` 은 .gitignore 에 박혀 있어요 — 회의 양식은 개인 설정이라 보호.

# 회의록 기능 켤지. false 면 /notes·자연어 트리거 모두 비활성.
enabled: true

# ── 포함할 섹션 (on/off) ─────────────────────────────────────
# 끄면 회의록에서 그 섹션이 빠져요. 모두 끄면 한 줄 요약만 나와요.
sections:
  summary: true          # 한 줄 요약 — 이 회의가 무엇이었는지 한 문장
  discussion: true       # 핵심 논의 — 오간 논점 항목별
  decisions: true        # 결정사항 — 확정된 결정만
  action_items: true     # 액션아이템 — 할 일 + 담당자 + 기한
  open_questions: true   # 미해결 질문 — 결론 못 낸 질문·보류

# ── 길이 ─────────────────────────────────────────────────────
# short  (각 항목 1줄) | medium  (1~2줄) | long  (맥락 한 줄 더)
length: medium

# ── 액션아이템 표기 형식 ─────────────────────────────────────
# checkbox : - [ ] 할 일 — 담당자 · 기한   (기본, 노션·텔레그램에 그대로 체크리스트)
# numbered : 1. 할 일 — 담당자 · 기한
# plain    : - 할 일 (담당자, 기한)
action_item_format: checkbox

# ── 즉시 ack 메시지 ──────────────────────────────────────────
# 회의 메모를 받으면 *바로* 텔레그램에 보내는 페르소나 톤 한 줄 (Claude 호출 안 함 = 즉시).
# 회의록 생성은 몇 초 걸리니, "정리 중" 신호를 주면 사용자가 안심해요.
# 비워두면 ack 안 보냄.
# 예시:
#   토니 스타크: "회의록? JARVIS, 핵심만 추려. 잠깐."
#   셜록: "흥미롭군. 회의의 뼈대를 추려 보겠네."
#   요다: "정리하면, 보일 것이다. 기다려라."
ack_message: ""
