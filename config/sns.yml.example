# 도클갱어 W6 부가기능 — MBTI SNS 자동 게시 설정 (예시)
#
# 1. 이 파일을 `config/sns.yml` 로 복사하세요:
#       cp config/sns.yml.example config/sns.yml
# 2. `/setup-sns` 이 갱이와 대화하며 mbti_tag 등을 채워줘요. 직접 손으로 편집해도 OK.
# 3. 봇이 매 `/sns` 호출마다 yml 을 reload — 재시작 불필요.
# 4. `config/sns.yml` 은 .gitignore 에 박혀 있어요 — 개인 설정이라 보호.
#
# ⚠️ API 키(MBTI_SNS_API_KEY)는 여기 아니라 `.env` 에 넣어요. 키 = 공개 글 쓰기 권한이라
#    공유·git 금지. 미설정 시 /sns 기능 자동 OFF (W2~W5 정상 동작).

# SNS 게시 기능 켤지. false 면 /sns 명령 비활성.
enabled: true

# ── 본인 MBTI 유형 ───────────────────────────────────────────
# 게시 시 글에 붙는 MBTI 태그. 예: "ENFP", "INTJ".
# 비워두면 태그 없이 게시돼요.
mbti_tag: ""

# ── SNS 글 권장 길이 (자) ────────────────────────────────────
# 변환된 글이 이 길이를 넘으면 부드럽게 잘라요. 280(트위터 등급)이 기본.
max_len: 280

# ── 변환 톤 힌트 ─────────────────────────────────────────────
# 페르소나에게 "어떤 느낌의 짧은 글로 바꿀지" 한 줄 힌트. 톤 자체는 페르소나가 결정.
# 예: "짧고 캐주얼하게, 솔직한 한두 문장" / "유머 한 스푼" / "담백하게 핵심만"
style: "짧고 캐주얼하게, 솔직한 한두 문장"

# ── 즉시 ack 메시지 ──────────────────────────────────────────
# /sns 를 받으면 *변환 시작 직전* 텔레그램에 보내는 한 줄 (Claude 호출 안 함 = 즉시).
# 변환에 몇 초 걸리니 "고치는 중" 신호를 주면 사용자가 안심해요.
# 비워두면 ack 안 보냄.
# 예시:
#   토니 스타크: "그 메모, 좀 멋지게 바꿔 줄게. 잠깐."
#   셜록: "흥미로운 한 줄이군. 다듬어 보겠네."
ack:
  converting: ""
